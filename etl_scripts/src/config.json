{
  "proyecto": {
    "nombre": "PYTHON_ETL",
    "version": "1.0.0",
    "descripcion": "Proyecto ETL para análisis de datos de crédito financiero",
    "autor": "botanicalex",
    "email": "alexavascolopera@hotmail.com"
  },
  "datos": {
    "archivo_entrada": "Base_de_datos.csv",
    "ruta_entrada": "../../../Base_de_datos.csv",
    "encoding": "utf-8",
    "separador": ","
  },
  "transformacion": {
    "variables_interes": [
      "credito",
      "usuario",
      "pago",
      "mora"
    ],
    "manejo_nulos": "eliminar",
    "outliers": "detectar"
  },
  "analisis": {
    "tipo": "EDA",
    "visualizaciones": true,
    "estadisticas_descriptivas": true,
    "correlaciones": true
  },
  "output": {
    "generar_reporte": true,
    "formato_graficos": "png",
    "guardar_datos_limpios": true
  }
}
