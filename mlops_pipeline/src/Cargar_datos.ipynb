    "def cargarDatos(filename='Base_de_datos.xlsx'):\n",
    "    df = pd.read_excel(filename)\n",
    "    print(f'Dataset cargado: {df.shape[0]} filas x {df.shape[1]} columnas')\n",
    "    return df\n",
    "\n",
    "df = cargarDatos()\n",
